# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# When adding env vars, update the schema in "src/env.js" too.

# ============================================
# PUBLIC (NEXT_PUBLIC_*) — exposed to browser
# ============================================

# Brand name shown in <title>, footer, etc.
NEXT_PUBLIC_SITE_NAME="Mobile Craft Bars"

# Booking provider URL — full path to the event type
# Calendly example: https://calendly.com/your-account/discovery-call
# Cal.com example:  https://cal.com/your-account/event-name
NEXT_PUBLIC_BOOKING_URL=""

# PostHog — analytics
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# Meta Pixel (client-side)
NEXT_PUBLIC_META_PIXEL_ID=""

# Google Analytics 4 measurement ID (G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# Meta domain verification token. Paste the value from
# Business Manager > Brand Safety > Domains > Verify > Meta-Tag Verification.
# When set, layout.tsx outputs <meta name="facebook-domain-verification" .../>.
NEXT_PUBLIC_META_DOMAIN_VERIFICATION=""

# Privacy policy URL displayed in the footer. Required for Meta ad approval.
# Can point to an external site (e.g. an existing apex-domain Framer page).
NEXT_PUBLIC_PRIVACY_POLICY_URL=""

# ============================================
# SERVER-ONLY — never exposed to browser
# ============================================

# Webhook signing secret for booking provider (Cal.com / Calendly)
CAL_WEBHOOK_SECRET=""

# Meta Conversions API access token (server-side CAPI)
META_CONVERSIONS_API_TOKEN=""

# Resend transactional email (for lead notification emails to the owner)
# Get your key at https://resend.com/api-keys
RESEND_API_KEY=""

# Email address that receives discovery-call lead notifications
LEAD_NOTIFY_EMAIL=""

# From address used when sending discovery-lead notification emails.
# Format: "Display Name <address@verified-domain.com>"
# Address domain must be verified in Resend (DNS records: SPF + DKIM + DMARC).
# Until your domain is verified, set this to "Mobile Craft Bars <onboarding@resend.dev>".
LEAD_FROM_EMAIL=""

# Skip env validation during Docker/CI builds
# SKIP_ENV_VALIDATION=1
